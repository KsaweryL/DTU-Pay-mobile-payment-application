          "firstName" : {
            "type" : "string"
          },
          "lastName" : {
            "type" : "string"
          },
          "merchantBankId" : {
            "type" : "string"
          }
        }
      },
      "PaymentRequest" : {
        "type" : "object",
        "properties" : {
